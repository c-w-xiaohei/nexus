{
  "name": "@nexus-js/testing",
  "version": "0.1.0",
  "description": "Testing utilities for Nexus applications",
  "private": false,
  "license": "MIT",
  "author": "Carson Yu",
  "repository": {
    "type": "git",
    "url": "https://github.com/c-w-xiaohei/nexus.git",
    "directory": "packages/testing"
  },
  "keywords": [
    "nexus",
    "testing",
    "mock",
    "unit-test"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@nexus-js/core": ">=0.1.2 <1"
  },
  "dependencies": {
    "neverthrow": "8.2.0"
  },
  "devDependencies": {
    "@nexus-js/core": "workspace:*",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vite-plugin-dts": "4.5.4",
    "vitest": "4.0.18"
  }
}
